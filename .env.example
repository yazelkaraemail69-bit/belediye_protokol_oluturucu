# OpenRouter API anahtarı — SADECE sunucu tarafında kullanılır, tarayıcıya gönderilmez.
# https://openrouter.ai/keys adresinden alın.
OPENROUTER_API_KEY=

# Backend proxy portu
PORT=8787

# İsteğe bağlı: OpenRouter başlıkları
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Belediye Protokol Olusturucu

# İş bölümü yapan 3 model (boş bırakılırsa varsayılanlar kullanılır)
# Varsayılanlar: anthropic/claude-opus-4.8, openai/gpt-5.6-terra-pro, google/gemini-2.5-pro
MODEL_ORDERER=
MODEL_WRITER=
MODEL_EDITOR=
