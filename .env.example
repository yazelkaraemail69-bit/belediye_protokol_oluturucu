# OpenRouter API anahtarı — SADECE sunucu tarafında kullanılır, tarayıcıya gönderilmez.
# https://openrouter.ai/keys adresinden alın.
OPENROUTER_API_KEY=

# Backend proxy portu
PORT=8787

# İsteğe bağlı: OpenRouter başlıkları
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Belediye Protokol Olusturucu

# Protokol planlayıcı (boş bırakılırsa deepseek/deepseek-chat-v3-0324)
MODEL_PLANNER=

# Instagram paylaşım metni yazarı (boş bırakılırsa google/gemini-2.5-pro)
MODEL_WRITER=
